#!/usr/bin/env bash
# Plugin sidecar launcher.
#
# Release mode (default): execs the compiled bun binary at
# $plugin_root/bin/mcp-quick-show (built by tools/build-plugin.sh).
#
# Dev mode (QUICKSHOW_DEV_SIDECAR=1): execs `bun sidecar/src/index.ts`
# from the source repo so TypeScript edits land in the next-spawned
# MCP server without a rebuild — the user still needs to /restart
# Claude Code to respawn, but the rebuild step drops out.
#
# Repo discovery walks up from the script's own resolved path. Works
# when the plugin is installed via the local-marketplace symlink
# (~/.claude/plugins/cache/local/quickshow/dev → $REPO/plugin) because
# `pwd -P` resolves the symlink chain back to the source checkout.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd -P)"
REPO_ROOT="$(cd "$PLUGIN_ROOT/.." && pwd -P)"

if [ -n "${QUICKSHOW_DEV_SIDECAR:-}" ]; then
    BUN="${BUN:-}"
    if [ -z "$BUN" ]; then
        for candidate in \
            "$HOME/.bun/bin/bun" \
            "/opt/homebrew/bin/bun" \
            "/usr/local/bin/bun"; do
            if [ -x "$candidate" ]; then
                BUN="$candidate"
                break
            fi
        done
    fi
    if [ -z "$BUN" ] || [ ! -x "$BUN" ]; then
        echo "[mcp-quick-show] QUICKSHOW_DEV_SIDECAR=1 but bun not found in ~/.bun/bin, /opt/homebrew/bin, or /usr/local/bin." >&2
        exit 1
    fi
    SIDECAR_ENTRY="$REPO_ROOT/sidecar/src/index.ts"
    if [ ! -f "$SIDECAR_ENTRY" ]; then
        echo "[mcp-quick-show] QUICKSHOW_DEV_SIDECAR=1 but sidecar source not found at $SIDECAR_ENTRY (launcher is outside its source repo — symlink the plugin from $REPO/plugin to use dev mode)." >&2
        exit 1
    fi
    exec "$BUN" "$SIDECAR_ENTRY" "$@"
fi

COMPILED="$PLUGIN_ROOT/bin/mcp-quick-show"
if [ ! -x "$COMPILED" ]; then
    echo "[mcp-quick-show] compiled sidecar not found at $COMPILED — run tools/build-plugin.sh." >&2
    exit 1
fi
exec "$COMPILED" "$@"
